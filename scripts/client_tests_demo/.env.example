# Environment file for run_tests.sh — copy to .env.test and fill in.
#
# The runner accepts either `=` or `:` as the key/value delimiter; this example
# uses `=`. Lines starting with `#` and blank lines are ignored. Real .env*
# files are gitignored — only this .env.example is committed.
#
# Two accounts are used:
#   - push account (sender or admin): used by T1 to POST to the listener.
#   - read account (normal or admin): used by T2-T9 for reads/search/NL query.
# A single admin account may be used for both if you prefer.

# Target — choose ONE of the following:
#
#   1. host (+ optional port). Plain hostname or IP. `port` is OPTIONAL — when
#      omitted the scheme's default port applies (80 for http, 443 for https).
#      `host` may include a scheme; without one it defaults to http://.
#        host=192.0.2.10           + port=8001  -> http://192.0.2.10:8001
#        host=threats.example.com  (no port)    -> http://threats.example.com   (80)
#        host=https://threats.example.com       -> https://threats.example.com  (443)
#   2. url (full base URL, including scheme). Use this for a reverse proxy /
#      path prefix (alias) — e.g. https://proxy.example.com/threatfeeds.
#
# If both are set, `url` wins and host/port are ignored (with a warning).
# A `url` MUST include the scheme (http:// or https://); a trailing slash is
# stripped. CLI: pass `--env <file>` to run_tests.sh.

host=192.0.2.10
port=8001

# host=https://threats.example.com              # HTTPS on the default port 443
# url=https://proxy.example.com/threatfeeds      # reverse-proxy alias / path prefix

# TLS certificate verification — leave OFF unless you must accept a self-signed
# or otherwise untrusted cert (e.g. internal HTTPS with a private CA).
# Truthy values: 1, true, yes, on. SECURITY: this disables cert validation for
# the whole run and exposes the session to MITM; only use on trusted networks.
# Equivalent CLI flag: -k / --insecure
# skip_tls_verify=true

# Push (sender) account — POSTs events to the listener (T1).
user_push=push-user
pass_push=changeme

# Read (normal) account — reads, search, and NL queries (T2-T9).
user_read=read-user
pass_read=changeme
